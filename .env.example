NODE_ENV=development
API_PORT=4000
COLLAB_PORT=4234

# Postgres (matches docker-compose service)
DATABASE_URL=postgres://nookapp:nookapp@localhost:5432/nookapp

# Auth
JWT_SECRET=change-me-min-32-characters-long-please-xxxxxxx
BETTER_AUTH_SECRET=change-me-min-32-characters-long-please-xxxxxxx
BETTER_AUTH_URL=http://localhost:4000

# LiveKit (self-hosted via docker-compose)
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=poc-gather-dev-secret-min-32-characters-long

# Email — "mailpit" in dev, "resend" in prod
MAIL_DRIVER=mailpit
MAIL_FROM="NookApp <noreply@nookapp.local>"
MAILPIT_HOST=localhost
MAILPIT_PORT=1025
RESEND_API_KEY=

# Web
NUXT_PUBLIC_API_BASE=http://localhost:4000/api/v1
NUXT_PUBLIC_AUTH_BASE=http://localhost:4000/api/auth
NUXT_PUBLIC_WEB_URL=http://localhost:4001
NUXT_PUBLIC_COLLAB_URL=ws://localhost:4234

# Monitoring — Sentry. Laisser vide en dev : le SDK reste alors inerte
# (aucun appel reseau, aucun compte requis).
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
NUXT_PUBLIC_SENTRY_DSN=
NUXT_PUBLIC_SENTRY_ENVIRONMENT=development
